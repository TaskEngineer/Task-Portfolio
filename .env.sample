# .env.example
# ------------------------------------------------------------------
# このファイルをコピーして .env を作成し、各変数を埋めてください。
# .env は .gitignore で除外済みのため Git にはコミットされません。
# ------------------------------------------------------------------

# S3 バケット名（例: task-portfolio-bucket）
BUCKET_NAME=

# CloudFront ディストリビューションID（例: E1ABCDEFGHIJKL）
# AWSコンソール → CloudFront → ディストリビューション一覧の "ID" 列
DISTRIBUTION_ID=